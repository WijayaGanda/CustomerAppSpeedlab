<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext traffic for all domains (development/sandbox) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    
    <!-- Specific domain configuration for Midtrans -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">midtrans.com</domain>
        <domain includeSubdomains="true">veritrans.co.id</domain>
        <domain includeSubdomains="true">gtflabs.io</domain>
        <domain includeSubdomains="true">al-pc-id-b.cdn.gtflabs.io</domain>
    </domain-config>
</network-security-config>
